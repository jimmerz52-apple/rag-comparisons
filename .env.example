# LLM backend: local (Ollama + sentence-transformers) or openai
LLM_BACKEND=local

# Ollama settings (used when LLM_BACKEND=local)
OLLAMA_BASE_URL=http://127.0.0.1:11434
LOCAL_CHAT_MODEL=llama3.2:3b
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
LOCAL_JUDGE_MODEL=llama3.2:3b

# OpenAI settings (only needed when LLM_BACKEND=openai)
# OPENAI_API_KEY=sk-...
# GRAPHRAG_API_KEY=${OPENAI_API_KEY}
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_JUDGE_MODEL=gpt-4o-mini
